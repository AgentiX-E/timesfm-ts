{
  "name": "@agentix-e/timesfm-web",
  "version": "0.3.2",
  "description": "TimesFM time-series forecasting for the browser — WebAssembly inference via onnxruntime-web",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
